{
  "permissions": {
    "allow": [
      "Bash(git commit:*)",
      "Bash(gh api /notifications:*)",
      "Bash(gh api notifications:*)",
      "Bash(gh api /user:*)",
      "Bash(.claude/scripts/record-quality-review.sh)",
      "Skill(quality-review)",
      "Skill(simplify)"
    ]
  },
  "extraKnownMarketplaces": {
    "tq-marketplace": {
      "source": {
        "source": "github",
        "repo": "MH4GF/tq"
      }
    }
  },
  "enabledPlugins": {
    "tq@tq-marketplace": true
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx -y gh-setup-hooks",
            "timeout": 120
          },
          {
            "type": "command",
            "command": "go install . && tq --version",
            "timeout": 120
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/check-quality-review.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-edit-go-quality.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/check-session-completion.sh"
          }
        ]
      }
    ]
  }
}
