{
  "permissions": {
    "allow": [
      "Bash(git commit:*)",
      "Bash(gh api /notifications:*)",
      "Bash(gh api notifications:*)",
      "Bash(gh api /user:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx -y gh-setup-hooks",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
