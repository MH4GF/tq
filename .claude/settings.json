{
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Bash(git commit:*)",
      "Bash(gh api /notifications:*)",
      "Bash(gh api notifications:*)",
      "Bash(gh api /user:*)",
      "Bash(gh pr:*)",
      "Bash(tq:*)",
      "Bash(sqlite3:*)",
      "Bash(goreleaser check:*)",
      "Bash(turso --version)",
      "Bash(turso auth:*)",
      "Bash(turso plan:*)",
      "Bash(turso db:*)",
      "Bash(./scripts/deadcode-check.sh)",
      "Bash(.claude/hooks/check-quality-review.sh)",
      "Bash(.claude/scripts/record-quality-review.sh)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:docs.github.com)",
      "WebFetch(domain:pkg.go.dev)",
      "WebFetch(domain:turso.tech)",
      "Skill(quality-review)",
      "Skill(simplify)"
    ],
    "deny": [
      "Bash(turso db destroy:*)",
      "Bash(turso db revert:*)",
      "Bash(go clean -modcache:*)",
      "Bash(gh release delete:*)",
      "Bash(gh release delete-asset:*)"
    ]
  },
  "extraKnownMarketplaces": {
    "tq-marketplace": {
      "source": {
        "source": "github",
        "repo": "MH4GF/tq"
      }
    }
  },
  "enabledPlugins": {
    "tq@tq-marketplace": true
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx -y gh-setup-hooks",
            "timeout": 120
          },
          {
            "type": "command",
            "command": "go install . && tq --version",
            "timeout": 120
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/check-quality-review.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-edit-go-quality.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/check-session-completion.sh"
          }
        ]
      }
    ]
  }
}
