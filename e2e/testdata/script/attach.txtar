# tq action attach: input-validation branches that don't require a live daemon.

exec tq project create demo /tmp/demo
exec tq task create 't' --project 1
exec tq action create 'x' --task 1 --title 'x'

# Action exists but has no daemon_short recorded yet (never dispatched).
! exec tq action attach 1
stderr 'has no daemon_short'

# Non-existent action: GetAction failure surfaces as "get action: ...".
! exec tq action attach 9999
stderr '^Error: get action: '
