# DB path precedence: --db flag > TQ_DB_PATH env > default.
# The harness Setup pins TQ_DB_PATH to $WORK/tq.db, so we contrast that
# against an explicit --db pointing at $WORK/alt.db.

exec tq --db $WORK/alt.db project create alt /tmp/alt
stdout 'project #1 created'

exec tq --db $WORK/alt.db project list
stdout '"name": "alt"'

exec tq project list
stdout '\[\]'

# --db wins even when TQ_DB_PATH points at a different (non-default) path.
env TQ_DB_PATH=$WORK/other.db
exec tq --db $WORK/alt.db project list
stdout '"name": "alt"'
