#!/bin/bash
# Fetch unresolved review threads and write a Markdown draft for /gh-ops:respond-review.
# Usage: gh-prepare-review-replies <PR_URL or PR_NUMBER>
set -euo pipefail

INPUT="${1:?Usage: gh-prepare-review-replies <PR_URL or PR_NUMBER>}"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

if [[ "$INPUT" =~ ^[0-9]+$ ]]; then
  NUMBER="$INPUT"
elif [[ "$INPUT" =~ github\.com/[^/]+/[^/]+/pull/([0-9]+) ]]; then
  NUMBER="${BASH_REMATCH[1]}"
else
  echo "Error: provide a PR URL or PR number: $INPUT" >&2
  exit 1
fi

JSON=$("${SCRIPT_DIR}/gh-unresolved-threads" "$INPUT")

COUNT=$(printf '%s' "$JSON" | jq 'length')
if [ "$COUNT" -eq 0 ]; then
  echo "No unresolved threads" >&2
  exit 0
fi

mkdir -p .claude/tmp
TIMESTAMP=$(date +%Y%m%d-%H%M%S)
OUTFILE=".claude/tmp/pr${NUMBER}-review-replies-${TIMESTAMP}.md"

{
  printf '# PR #%s Review Replies\n\n' "$NUMBER"
  printf '<!-- Generated by gh-prepare-review-replies. Used by /gh-ops:respond-review Phase 2. -->\n\n'
  printf '%s' "$JSON" | jq -r '
    .[] |
    . as $thread |
    $thread.comments.nodes[0] as $first |
    ($first.author.login // "unknown") as $author |
    (if $first.path == null then "(general)"
     elif $first.line then "\($first.path):\($first.line)"
     else $first.path end) as $loc |
    "## \($loc) by @\($author)\n\n" +
    "- **Thread ID**: `\($thread.id)`\n\n" +
    ($thread.comments.nodes | map("> " + (.body | gsub("\n"; "\n> "))) | join("\n\n---\n\n")) +
    "\n\n**Classification**: _(No action / Resolve without code change / Action required)_\n\n" +
    "**Reply draft**:\n\n_(empty)_\n\n---\n"
  '
} > "$OUTFILE"

printf '%s\n' "$OUTFILE"
