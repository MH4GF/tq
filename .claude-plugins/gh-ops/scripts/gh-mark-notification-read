#!/bin/bash
# Mark one or more GitHub notification threads as read
# Usage: gh-mark-notification-read <thread_id> [<thread_id>...]
set -euo pipefail

if [[ $# -lt 1 ]]; then
  echo "Usage: gh-mark-notification-read <thread_id> [<thread_id>...]" >&2
  exit 1
fi

for thread_id in "$@"; do
  gh api -X PATCH "/notifications/threads/${thread_id}"
  echo "Marked: ${thread_id}" >&2
done
